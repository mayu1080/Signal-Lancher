{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://signal-launcher.local/show.schema.json",
  "title": "Signal Launcher Show Config",
  "type": "object",
  "required": ["projectName", "appMode", "midiInput", "targets", "triggers"],
  "additionalProperties": false,
  "properties": {
    "projectName": {
      "type": "string",
      "minLength": 1,
      "description": "Show / project display name"
    },
    "appMode": {
      "type": "string",
      "enum": ["live", "dryRun"],
      "description": "Initial application mode"
    },
    "midiInput": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "activeDevice": {
          "type": "string",
          "description": "Exact MIDI input device name selected in the app (preferred on connect)"
        },
        "autoDetect": {
          "type": "string",
          "description": "Substring to match MIDI input device name (e.g. APC mini)"
        },
        "preferredDevices": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Fallback device name substrings if autoDetect fails"
        }
      }
    },
    "targets": {
      "type": "array",
      "items": { "$ref": "#/$defs/target" }
    },
    "triggers": {
      "type": "array",
      "items": { "$ref": "#/$defs/trigger" }
    },
    "schedules": {
      "type": "array",
      "items": { "$ref": "#/$defs/schedule" }
    }
  },
  "$defs": {
    "targetBase": {
      "type": "object",
      "required": ["id", "label", "type"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "type": { "type": "string", "enum": ["osc", "udp", "midi"] }
      }
    },
    "oscTarget": {
      "allOf": [
        { "$ref": "#/$defs/targetBase" },
        {
          "type": "object",
          "required": ["host", "port"],
          "properties": {
            "type": { "const": "osc" },
            "host": { "type": "string", "minLength": 1 },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        }
      ]
    },
    "udpTarget": {
      "allOf": [
        { "$ref": "#/$defs/targetBase" },
        {
          "type": "object",
          "required": ["host", "port"],
          "properties": {
            "type": { "const": "udp" },
            "host": { "type": "string", "minLength": 1 },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "encoding": {
              "type": "string",
              "enum": ["utf-8", "ascii", "hex"],
              "default": "utf-8"
            }
          }
        }
      ]
    },
    "midiTarget": {
      "allOf": [
        { "$ref": "#/$defs/targetBase" },
        {
          "type": "object",
          "required": ["outputDevice"],
          "properties": {
            "type": { "const": "midi" },
            "outputDevice": { "type": "string", "minLength": 1 },
            "channel": { "type": "integer", "minimum": 1, "maximum": 16 }
          }
        }
      ]
    },
    "target": {
      "oneOf": [
        { "$ref": "#/$defs/oscTarget" },
        { "$ref": "#/$defs/udpTarget" },
        { "$ref": "#/$defs/midiTarget" }
      ]
    },
    "triggerMidiInput": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["note", "cc"] },
        "note": { "type": "integer", "minimum": 0, "maximum": 127 },
        "cc": { "type": "integer", "minimum": 0, "maximum": 127 },
        "channel": { "type": "integer", "minimum": 1, "maximum": 16 }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "note" } } },
          "then": { "required": ["note"] }
        },
        {
          "if": { "properties": { "type": { "const": "cc" } } },
          "then": { "required": ["cc"] }
        }
      ]
    },
    "triggerScreenInput": {
      "type": "object",
      "required": ["buttonId"],
      "properties": {
        "buttonId": { "type": "string", "minLength": 1 }
      }
    },
    "triggerKeyboardInput": {
      "type": "object",
      "required": ["key"],
      "properties": {
        "key": { "type": "string", "minLength": 1 }
      }
    },
    "triggerInputs": {
      "type": "object",
      "properties": {
        "midi": {
          "type": "array",
          "items": { "$ref": "#/$defs/triggerMidiInput" }
        },
        "screen": {
          "type": "array",
          "items": { "$ref": "#/$defs/triggerScreenInput" }
        },
        "keyboard": {
          "type": "array",
          "items": { "$ref": "#/$defs/triggerKeyboardInput" }
        }
      }
    },
    "action": {
      "type": "object",
      "required": ["target"],
      "properties": {
        "target": { "type": "string", "minLength": 1 },
        "address": { "type": "string" },
        "args": { "type": "array" },
        "message": { "type": "string" },
        "note": { "type": "integer", "minimum": 0, "maximum": 127 },
        "velocity": { "type": "integer", "minimum": 0, "maximum": 127 },
        "controller": { "type": "integer", "minimum": 0, "maximum": 127 },
        "value": { "type": "integer", "minimum": 0, "maximum": 127 },
        "durationMs": { "type": "integer", "minimum": 0 }
      }
    },
    "trigger": {
      "type": "object",
      "required": ["triggerId", "label", "actions"],
      "properties": {
        "triggerId": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "group": { "type": "string" },
        "color": { "type": "string" },
        "inputs": { "$ref": "#/$defs/triggerInputs" },
        "actions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/action" }
        }
      }
    },
    "schedule": {
      "type": "object",
      "required": ["scheduleId", "enabled", "label", "mode", "time", "triggerId"],
      "properties": {
        "scheduleId": { "type": "string", "minLength": 1 },
        "enabled": { "type": "boolean" },
        "label": { "type": "string", "minLength": 1 },
        "mode": { "type": "string", "enum": ["daily", "oneShot"] },
        "time": {
          "type": "string",
          "pattern": "^\\d{2}:\\d{2}:\\d{2}$"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "triggerId": { "type": "string", "minLength": 1 }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "oneShot" } } },
          "then": { "required": ["date"] }
        }
      ]
    }
  }
}
